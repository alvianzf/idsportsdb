# Production / native (Capacitor) build config for apps/web.
#
# `vite build` runs in "production" mode by default, so this file (as
# `.env.production`, untracked — copy this example and fill in real values)
# is loaded automatically and overrides VITE_API_BASE_URL from `.env`.
#
# This is required for Capacitor (Android/iOS) builds: the app runs on a
# device/emulator, so "http://localhost:4000" refers to the device itself,
# not your dev machine or the deployed API server. Point this at a
# network-reachable absolute URL (LAN IP, tunnel, or public domain).

VITE_API_BASE_URL="https://api.simo-konibatam.com/api/v1"
