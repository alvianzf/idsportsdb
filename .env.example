# PostgreSQL (apps/api)
DATABASE_URL="postgresql://koni:koni@localhost:5432/koni_batam?schema=public"

# Auth
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API server
PORT=4000
API_BASE_URL="http://localhost:4000"

# Frontend (apps/web) - Vite env vars must be prefixed VITE_
VITE_API_BASE_URL="http://localhost:4000/api/v1"

# Local file storage
UPLOAD_DIR="./uploads"

# Digital card verification base URL (encoded in QR codes)
CARD_VERIFY_BASE_URL="http://localhost:5173/verify"

# Seed credentials (used by prisma/seed.ts — change before production)
SEED_PASSWORD="password123"

# App base URL (used in email links)
APP_BASE_URL="http://localhost:5173"

# SMTP (transactional email)
SMTP_HOST="smtp.sumopod.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
SMTP_FROM="no-reply@batam.koni.go.id"
