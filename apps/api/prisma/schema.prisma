// KONI Batam — Prisma schema
// See specs/004-atlet/spec.md etc. for the spec each model implements.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN_KONI
  ADMIN_KONI
  ADMIN_CABOR
  ATLET
}

enum Gender {
  L // Laki-laki
  P // Perempuan
}

enum AthleteStatus {
  ACTIVE
  INACTIVE
  INJURED
  TRAINING_CAMP // pemusatan latihan
  TRANSFERRED // mutasi
}

// Revisi 2026-07-12: tingkat atlet final — Kota/Provinsi/Nasional/Internasional.
enum AthleteLevel {
  KOTA
  PROVINSI
  NASIONAL
  INTERNASIONAL
}

// Revisi 2026-07-12: kalender event (spec 017).
enum EventStatus {
  ON_TRACK
  SELESAI
  DIBATALKAN
  DIUNDUR
}

enum EventLevel {
  KOTA_KABUPATEN
  PROVINSI
  NASIONAL
  INTERNASIONAL
  OPEN
}

enum CompetitionLevel {
  KOTA
  PROVINSI
  NASIONAL
  INTERNASIONAL
}

enum Medal {
  GOLD
  SILVER
  BRONZE
  NONE
}

enum DocumentType {
  KTP
  KK
  AKTA_KELAHIRAN
  PAS_FOTO
  SERTIFIKAT_PRESTASI
}

enum MonitoringEventType {
  INJURY
  MUTATION
  TRAINING_CAMP
  SELECTION
  STATUS_CHANGE
}

enum MutationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  role             Role
  fullName         String
  avatarUrl        String?
  isActive         Boolean  @default(true)

  // Required for ADMIN_CABOR; null for other roles (spec 001)
  cabangOlahragaId String?
  cabangOlahraga   CabangOlahraga? @relation(fields: [cabangOlahragaId], references: [id])

  // Links an ATLET-role user to their own athlete record (spec 001, 004)
  athleteId        String?  @unique
  athlete          Atlet?   @relation(fields: [athleteId], references: [id])

  // Password reset (specs/001-auth-rbac — forgot-password flow)
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  auditLogs        AuditLog[]
  monitoringEvents MonitoringEvent[] @relation("MonitoringCreatedBy")
  articles         Article[]

  @@index([cabangOlahragaId])
}

model CabangOlahraga {
  id                  String   @id @default(uuid())
  nama                String   @unique
  ketuaCabor          String?
  sekretariat         String?
  // National sports organisation for this discipline (e.g. FORKI for Karate)
  organisasiNasional  String?
  logoOrganisasiUrl   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  atlets        Atlet[]
  pelatihs      Pelatih[]
  pengurus      PengurusCabor[]
  users         User[]
  atletTambahan AtletCabor[]
  documents     CaborDocument[]
  events        Event[]

  // jumlahAtlet / jumlahPelatih (Modul E) are derived via _count, not stored;
  // jumlahAtlet includes athletes whose primary cabor is this one plus those
  // who additionally compete here via AtletCabor (atletTambahan).
}

// Revisi 2026-07-12: slider foto full-width di landing page, dikelola
// superadmin (spec 019-landing-slider). Rekomendasi gambar 1920×640 (3:1).
model SliderImage {
  id        String   @id @default(uuid())
  imageUrl  String
  caption   String?
  linkUrl   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

// Revisi 2026-07-12: kalender event KONI Batam (spec 017-event-calendar).
model Event {
  id               String          @id @default(uuid())
  namaKejuaraan    String
  tingkat          EventLevel
  lokasi           String?
  deskripsi        String?
  tanggalMulai     DateTime
  tanggalSelesai   DateTime?
  cabangOlahragaId String?
  cabangOlahraga   CabangOlahraga? @relation(fields: [cabangOlahragaId], references: [id], onDelete: SetNull)
  status           EventStatus     @default(ON_TRACK)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([tanggalMulai])
  @@index([status])
}

// SK (Surat Keputusan / decree) and other official documents for a CabangOlahraga.
model CaborDocument {
  id               String   @id @default(uuid())
  caborId          String
  cabor            CabangOlahraga @relation(fields: [caborId], references: [id], onDelete: Cascade)
  jenis            String   // e.g. "SK Pengurus", "SK Pembentukan", "Sertifikat Afiliasi"
  nomorDokumen     String?  // document/decree number
  tanggalDokumen   DateTime?
  deskripsi        String?
  fileUrl          String
  uploadedAt       DateTime @default(now())

  @@index([caborId])
}

model Atlet {
  id                String        @id @default(uuid())
  nomorIndukAtlet   String        @unique
  nomorRegistrasi   String        @unique
  namaLengkap       String
  nik               String        @unique
  // Revisi 2026-07-12: tempat/tanggal lahir on hold — optional, hidden from forms.
  tempatLahir       String?
  tanggalLahir      DateTime?
  jenisKelamin      Gender
  alamat            String
  // Not in the source PDF field list; added to support the
  // "data atlet per kecamatan" report (Modul H). See spec 004 open questions.
  kecamatan         String?
  nomorHp           String?
  email             String?
  fotoUrl           String?

  cabangOlahragaId  String
  cabangOlahraga    CabangOlahraga @relation(fields: [cabangOlahragaId], references: [id])

  statusAtlet       AthleteStatus @default(ACTIVE)
  // Revisi 2026-07-12: tingkat atlet TBD — optional until the client finalizes levels.
  tingkatAtlet      AthleteLevel?
  pendidikan        String?
  pekerjaan         String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  documents        AtletDocument[]
  prestasis        Prestasi[]
  monitoringEvents MonitoringEvent[]
  cards            AtletCard[]
  user             User?

  // Additional sport disciplines this athlete also competes in, beyond
  // their primary `cabangOlahragaId` (spec 004 — multi-cabor athletes).
  caborTambahan    AtletCabor[]

  @@index([cabangOlahragaId])
  @@index([statusAtlet])
  @@index([kecamatan])
  @@index([cabangOlahragaId, statusAtlet])
}

// Join table for athletes who compete in more than one sport discipline.
// `Atlet.cabangOlahragaId` remains the athlete's primary/home cabor; rows
// here represent additional cabor memberships. See spec 004.
model AtletCabor {
  id               String         @id @default(uuid())
  atletId          String
  atlet            Atlet          @relation(fields: [atletId], references: [id], onDelete: Cascade)
  cabangOlahragaId String
  cabangOlahraga   CabangOlahraga @relation(fields: [cabangOlahragaId], references: [id], onDelete: Cascade)
  nomorIndukAtlet  String?
  nomorRegistrasi  String?
  createdAt        DateTime       @default(now())

  @@unique([atletId, cabangOlahragaId])
  @@index([cabangOlahragaId])
}

model AtletDocument {
  id         String       @id @default(uuid())
  atletId    String
  atlet      Atlet        @relation(fields: [atletId], references: [id], onDelete: Cascade)
  type       DocumentType
  fileUrl    String
  uploadedAt DateTime     @default(now())

  @@index([atletId, type])
}

model Pelatih {
  id                 String   @id @default(uuid())
  namaPelatih        String
  nomorLisensi       String   @unique
  cabangOlahragaId   String
  cabangOlahraga     CabangOlahraga @relation(fields: [cabangOlahragaId], references: [id])
  tingkatanLisensi   String
  masaBerlakuMulai   DateTime?
  masaBerlakuAkhir   DateTime?
  // Free text for v1; normalize to a separate table if structured history is needed (spec 005).
  riwayatKepelatihan String?  @db.Text

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([cabangOlahragaId])
}

model PengurusCabor {
  id               String   @id @default(uuid())
  cabangOlahragaId String
  cabangOlahraga   CabangOlahraga @relation(fields: [cabangOlahragaId], references: [id])
  namaPengurus     String
  jabatan          String
  masaBaktiMulai   DateTime
  masaBaktiAkhir   DateTime
  kontak           String?

  // Hierarchical org structure (specs/006-pengurus-cabor/spec.md §"Struktur Organisasi")
  reportsToId      String?
  reportsTo        PengurusCabor?  @relation("PengurusHierarchy", fields: [reportsToId], references: [id], onDelete: SetNull)
  reports          PengurusCabor[] @relation("PengurusHierarchy")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([cabangOlahragaId])
  @@index([reportsToId])
}

model Prestasi {
  id               String   @id @default(uuid())
  atletId          String
  atlet            Atlet    @relation(fields: [atletId], references: [id], onDelete: Cascade)
  namaKejuaraan    String
  tingkatKejuaraan CompetitionLevel
  tahun            Int
  medali           Medal
  peringkat        Int?
  sertifikatUrl    String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([atletId])
  @@index([tahun])
  @@index([medali])
  @@index([tingkatKejuaraan])
  @@index([tahun, tingkatKejuaraan, medali])
}

// Unified monitoring/timeline log for Modul G (cedera, mutasi, pemusatan latihan,
// seleksi atlet, perubahan status). See spec 008 for rationale vs. separate tables.
model MonitoringEvent {
  id             String          @id @default(uuid())
  atletId        String
  atlet          Atlet           @relation(fields: [atletId], references: [id], onDelete: Cascade)
  type           MonitoringEventType
  description    String?         @db.Text
  fromValue      String?
  toValue        String?
  mutationStatus MutationStatus? // only meaningful when type = MUTATION

  eventDate      DateTime        @default(now())

  createdById    String
  createdBy      User            @relation("MonitoringCreatedBy", fields: [createdById], references: [id])

  createdAt      DateTime        @default(now())

  @@index([atletId, type])
  @@index([type, mutationStatus])
}

// Digital athlete card (Modul I). QR encodes a public verify URL containing cardCode.
// Revisi 2026-07-12: modul kartu atlet digital dibatalkan. Model dipertahankan
// agar tabel/data lama tidak terhapus oleh db push; tidak ada kode yang memakainya.
model AtletCard {
  id           String    @id @default(uuid())
  atletId      String
  atlet        Atlet     @relation(fields: [atletId], references: [id], onDelete: Cascade)
  cardCode     String    @unique
  qrPayloadUrl String
  issuedAt     DateTime  @default(now())
  expiresAt    DateTime?
  isRevoked    Boolean   @default(false)

  @@index([atletId, isRevoked])
}

// News/announcement CMS surfaced on the public landing page (specs/011-artikel/spec.md).
model Article {
  id            String    @id @default(uuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String    @db.Text
  coverImageUrl String?
  published     Boolean   @default(false)
  publishedAt   DateTime?

  authorId      String
  author        User      @relation(fields: [authorId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([authorId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String // CREATE | UPDATE | DELETE
  entity    String // "Atlet", "Pelatih", etc.
  entityId  String
  changes   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
